# Server
PORT=8080

# Database
DATABASE_URL=postgres://shakedown:shakedown@db:5432/shakedown?sslmode=disable

# Storage
STORAGE_ROOT=/data/audio

# Auth - set to true to bypass OIDC for local development
DISABLE_AUTH=true

# OIDC (Pocket ID) - not required when DISABLE_AUTH=true
OIDC_ISSUER=https://your-pocket-id-instance.example.com
OIDC_CLIENT_ID=shakedown
OIDC_CLIENT_SECRET=your-client-secret
APP_BASE_URL=http://localhost:8080

# Session
SESSION_SECRET=change-this-to-a-random-32-byte-secret

# Processing
PROCESSING_MAX_WORKERS=4
PROCESSING_TIMEOUT_SECONDS=300

# Upload
UPLOAD_MAX_SIZE_MB=500
